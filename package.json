{
  "name": "liquidb",
  "version": "1.13.0",
  "electronVersion": "39.1.1",
  "description": "Modern Database Management for macOS",
  "author": {
    "name": "LiquidB",
    "email": "team@liquidb.app"
  },
  "license": "MIT",
  "homepage": "https://liquidb.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/liquidb-app/LiquiDB"
  },
  "keywords": [
    "database",
    "management",
    "macos",
    "electron",
    "react",
    "tailwind",
    "typescript"
  ],
  "main": "electron-dist/electron/main.js",
  "private": true,
  "scripts": {
    "preload:build": "tsc -p tsconfig.preload.json",
    "helper:build": "tsc -p tsconfig.helper.json",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "dev": "bun run electron:compile && bun run preload:build && bun run helper:build && concurrently \"next dev --turbopack\" \"wait-on http://localhost:3000 && NODE_OPTIONS='--import tsx' USE_DEV_SERVER=true electron .\"",
    "dev:minimal": "bun run electron:compile && bun run preload:build && LOG_LEVEL=ERROR concurrently \"next dev\" \"wait-on http://localhost:3000 && NODE_OPTIONS='--import tsx' USE_DEV_SERVER=true electron .\"",
    "dev:quiet": "bun run electron:compile && bun run preload:build && LOG_LEVEL=WARN concurrently \"next dev\" \"wait-on http://localhost:3000 && NODE_OPTIONS='--import tsx' USE_DEV_SERVER=true electron .\"",
    "dev:normal": "bun run electron:compile && bun run preload:build && LOG_LEVEL=INFO concurrently \"next dev\" \"wait-on http://localhost:3000 && NODE_OPTIONS='--import tsx' USE_DEV_SERVER=true electron .\"",
    "dev:debug": "bun run electron:compile && bun run preload:build && LOG_LEVEL=DEBUG concurrently \"next dev\" \"wait-on http://localhost:3000 && NODE_OPTIONS='--import tsx' USE_DEV_SERVER=true electron .\"",
    "dev:verbose": "bun run electron:compile && bun run preload:build && LOG_LEVEL=VERBOSE concurrently \"next dev\" \"wait-on http://localhost:3000 && NODE_OPTIONS='--import tsx' USE_DEV_SERVER=true electron .\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "electron": "tsx electron/main.ts",
    "electron:build": "bun run electron:compile && next build && electron-builder",
    "electron:build:mac": "bun run electron:compile && next build && electron-builder --mac --publish never",
    "electron:build:mac:verbose": "bun run electron:compile && next build && DEBUG=\"electron-builder\" electron-builder --mac",
    "postinstall": "electron-builder install-app-deps && node scripts/fix-tar-vulnerability.js"
  },
  "build": {
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "liquidb-app",
      "repo": "LiquiDB"
    },
    "appId": "com.liquidb.app",
    "productName": "LiquiDB",
    "files": [
      "electron-dist/**/*",
      "helper/**/*",
      "helper-dist/**/*",
      "out/**/*",
      "public/**/*",
      "package.json",
      "!node_modules/sharp/**/*",
      "!node_modules/@img/sharp-darwin-arm64/**/*",
      "!node_modules/@next/swc-darwin-arm64/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "build/**",
      "out/**",
      "helper/**",
      "helper-dist/**",
      "public/**"
    ],
    "directories": {
      "buildResources": "build"
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "identity": "-",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "publish": {
        "provider": "github",
        "owner": "liquidb-app",
        "repo": "LiquiDB"
      }
    }
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/canvas-confetti": "^1.9.0",
    "@vercel/analytics": "1.5.0",
    "archiver": "^7.0.1",
    "auto-launch": "^5.0.6",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.35.2",
    "geist": "^1.7.0",
    "lucide-react": "^0.554.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "3.5.0",
    "semver": "^7.7.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/archiver": "^7.0.0",
    "@types/auto-launch": "^5.0.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "concurrently": "^9.2.1",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "electron": "^39.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "tar": "^7.5.2"
  }
}
